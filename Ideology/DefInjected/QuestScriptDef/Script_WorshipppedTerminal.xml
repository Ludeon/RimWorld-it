<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN:
    <li>terminalHackedMessage->Terminal hacked. You've collected the information and can now leave.</li>
  -->
  <Hack_WorshippedTerminal.questContentRules.rulesStrings>
    <li>terminalHackedMessage->Terminal hackerato. Hai raccolto le informazioni e ora puoi andartene.</li>
  </Hack_WorshippedTerminal.questContentRules.rulesStrings>
  <!-- EN:
    <li>questDescription->You've learned of an ancient terminal that contains information about the [relic_name]. However, the terminal is surrounded by a tribal village, and the locals venerate it. They aren't part of any major faction.\n\n[visitInfo]</li>
    <li>visitInfo(allowViolentQuests==true)->They are willing to let you visit on the pretense of worshiping it, but they will attack when you touch it.\n\nYou can attack the village from the outside, or enter peacefully and try to quickly escape with the data from the terminal.\n\nBeware - If you spend over [timer_duration] in the village or build anything near it, the locals will attack, and call reinforcements.</li>
    <li>visitInfo(allowViolentQuests==false)->They are willing to let you visit.</li>
  -->
  <Hack_WorshippedTerminal.questDescriptionRules.rulesStrings>
    <li>questDescription->Hai saputo di un terminale antico che contiene informazioni su [relic_name]. Tuttavia, il terminale è circondato da un villaggio tribale e i locali lo venerano. Non fanno parte di alcuna fazione importante.\n\n[visitInfo]</li>
    <li>visitInfo(allowViolentQuests==true)->Sono disposti a lasciarti visitare con il pretesto di adorarlo, ma ti attaccheranno quando lo toccherai.\n\nPuoi attaccare il villaggio dall'esterno oppure entrare pacificamente e tentare di fuggire rapidamente con i dati dal terminale.\n\nAttenzione: se rimani nel villaggio per più di [timer_duration] o costruisci qualcosa nelle vicinanze, i locali attaccheranno e chiameranno rinforzi.</li>
    <li>visitInfo(allowViolentQuests==false)->Sono disposti a lasciartelo visitare.</li>
  </Hack_WorshippedTerminal.questDescriptionRules.rulesStrings>
  <!-- EN:
    <li>questName->The [adj] [terminalName]</li>
    <li>adj->worshipped</li>
    <li>adj->venerated</li>
    <li>adj->ancient</li>
    <li>adj->villager's</li>
    <li>adj->village</li>
    <li>adj->tribal</li>
    <li>adj->secret</li>
    <li>terminalName(p=4)->terminal</li>
    <li>terminalName->machine</li>
    <li>terminalName->device</li>
    <li>terminalName->screen</li>
    <li>terminalName->computer</li>
    <li>terminalName->databank</li>
    <li>terminalName->database</li>
    <li>terminalName->silicon</li>
  -->
  <Hack_WorshippedTerminal.questNameRules.rulesStrings>
    <!-- "The [adj] [noun]": in italiano l'articolo dipende da genere e iniziale del nome
         (il/lo/l'/la) e l'aggettivo deve concordare. Inoltre "village/villager's" non sono
         aggettivi ma complementi ("del villaggio") → vanno post-nominali, non nello slot
         aggettivo (era la causa di "Il del villaggio terminale"). Articolo cotto nel nome;
         modificatore (aggettivo concordato o complemento) sempre post-nominale. I pesi delle
         due tracce (9/2) preservano la prevalenza dei nomi maschili della lista originale. -->
    <li>questName(p=9)->[terminal_m_def] [modM]</li>
    <li>questName(p=2)->[terminal_f_def] [modF]</li>
    <li>terminal_m_def(p=4)->il terminale</li>
    <li>terminal_m_def->il dispositivo</li>
    <li>terminal_m_def->lo schermo</li>
    <li>terminal_m_def->il computer</li>
    <li>terminal_m_def->il silicio</li>
    <li>terminal_m_def->il database</li>
    <li>terminal_f_def->la macchina</li>
    <li>terminal_f_def->la banca dati</li>
    <li>modM(p=5)->[adjM]</li>
    <li>modM(p=2)->[complement]</li>
    <li>modF(p=5)->[adjF]</li>
    <li>modF(p=2)->[complement]</li>
    <li>adjM->venerato</li>
    <li>adjM->adorato</li>
    <li>adjM->antico</li>
    <li>adjM->segreto</li>
    <li>adjM->tribale</li>
    <li>adjF->venerata</li>
    <li>adjF->adorata</li>
    <li>adjF->antica</li>
    <li>adjF->segreta</li>
    <li>adjF->tribale</li>
    <li>complement->del villaggio</li>
    <li>complement->del villaggio tribale</li>
  </Hack_WorshippedTerminal.questNameRules.rulesStrings>
  
</LanguageData>