    <li>r_logentry->[INITIATOR_nameDef] [disturbed] [RECIPIENT_nameDef] [talkingAbout] [subjectDisturbing].</li>
    <li>r_logentry->[INITIATOR_nameDef] [spoke] [RECIPIENT_nameDef] [darkSpeechAdverb] a proposito [subjectDisturbing].</li>
    <li>spoke->ha parlato con</li>
    <li>spoke->ha sussurrato qualcosa a</li>
    <li>spoke->ha balbettato qualcosa a</li>
    <li>spoke->ha gemuto qualcosa a</li>
    <li>spoke->ha ringhiato qualcosa davanti a</li>
    <li>spoke->ha detto cose sconnesse a</li>
    <li>spoke(p=5)->[rambled]</li>
    <li>subjectDisturbing->[subjectDarkStudy]</li>
    <li>subjectDisturbing->[subjectInsane]</li>
    <li>disturbed->ha turbato</li>
    <li>disturbed->ha inorridito</li>
    <li>disturbed->ha spaventato</li>
    <li>disturbed->ha infastidito</li>
    <li>disturbed->ha sconvolto</li>
    <li>disturbed->ha disturbato</li>
    <li>disturbed->ha disorientato</li>
    <li>disturbed->ha irritato</li>
    <li>disturbed->ha allarmato</li>
    <li>disturbed->ha angosciato</li>
    <li>disturbed->ha costernato</li>
    <li>maybeDarkSpeechAdverb-></li>
    <li>maybeDarkSpeechAdverb->[darkSpeechAdverb]</li>
    <!-- subjectDisturbing e' genitivo → talkingAbout senza prep finale -->
    <li>talkingAbout->parlando</li>
    <li>talkingAbout->cercando di discutere</li>
    <li>talkingAbout->lamentandosi [maybeDarkSpeechAdverb] a proposito</li>
    <li>talkingAbout->evocando [maybeDarkSpeechAdverb] l’argomento</li>
