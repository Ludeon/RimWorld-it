    <li>disturbed->unnerved</li>
    <li>disturbed->alarmed</li>
    <li>disturbed->distressed</li>
    <li>disturbed->dismayed</li>
    <li>maybeDarkSpeechAdverb-></li>
    <li>maybeDarkSpeechAdverb->[darkSpeechAdverb]</li>
