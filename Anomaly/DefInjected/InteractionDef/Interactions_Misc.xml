    <li>subjectDisturbing->[subjectInsane]</li>
    <li>disturbed->disturbed</li>
    <li>disturbed->horrified</li>
    <li>disturbed->frightened</li>
    <li>disturbed->upset</li>
    <li>disturbed->perturbed</li>
    <li>disturbed->unsettled</li>
