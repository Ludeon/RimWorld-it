<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN:
    <li>WordImperial(p=4)->[SylB][SylB]</li>
    <li>WordImperial(p=2)->[SylB][SylB][SylB]</li>
    <li>WordImperial(p=0.2)->[SylB][SylB][SylB][SylB]</li>
  -->
  <EmpireNameUtility.rulePack.rulesStrings>
    <li>WordImperial(p=4)->[SylB][SylB]</li>
    <li>WordImperial(p=2)->[SylB][SylB][SylB]</li>
    <li>WordImperial(p=0.2)->[SylB][SylB][SylB][SylB]</li>
  </EmpireNameUtility.rulePack.rulesStrings>
  
  <!-- EN:
    <li>r_name(p=2)->[WordTribal] [WordTribal]</li>
    <li>r_name->[WordTribal] '[AnimalBadass]' [WordTribal]</li>
    <li>r_name->[Color] [WordTribal]</li>
    <li>r_name->[WordTribal] [Animal]</li>
    <li>r_name->[Animal] [WordTribal]</li>
    <li>r_name->[Color] [Animal]</li>
  -->
  <NamerPersonCorunan.rulePack.rulesStrings>
    <li>r_name(p=2)->[WordTribal] [WordTribal]</li>
    <li>r_name->[WordTribal] '[AnimalBadass]' [WordTribal]</li>
    <!-- parola tribale = nome inventato senza genere, fa da "cognome": la parola descrittiva reale precede -->
    <li>r_name->[Color] [WordTribal]</li>
    <li>r_name->[Animal] [WordTribal]</li>
    <!-- animale + colore: vera concordanza aggettivo-sostantivo, sdoppiata per genere -->
    <li>r_name->[Animal_Masculine] [Color_Masculine]</li>
    <li>r_name->[Animal_Feminine] [Color_Feminine]</li>
  </NamerPersonCorunan.rulePack.rulesStrings>
  
</LanguageData>