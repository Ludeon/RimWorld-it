<?xml version="1.0" encoding="UTF-8"?>
<LanguageData>
  
  <!-- EN:
    <li>businessname->Names/Business</li>
    <li>businesstype->Words/Nouns/BusinessTypes</li>
  -->
  <NamerTraderGeneral.rulePack.rulesFiles>
    <li>businessname->Names/Business</li>
    <li>businesstype->Words/Nouns/BusinessTypes</li>
    <!-- IT: marchi descrittivi al genitivo. Le liste *_Genitive_* hanno la
         preposizione articolata gia' fusa e accordata (del/dello/dell'/della),
         generate da scripts/gen_genitive_lists.py dai sorgenti *_Singular_*;
         il file porta il genere, cosi' il colore/aggettivo posposto concorda. -->
    <li>animalgen_m->Words/Nouns/Animals_Genitive_Masculine</li>
    <li>animalgen_f->Words/Nouns/Animals_Genitive_Feminine</li>
    <li>natgen_m->Words/Nouns/NaturalObject_Genitive_Masculine</li>
    <li>natgen_f->Words/Nouns/NaturalObject_Genitive_Feminine</li>
    <li>treegen_m->Words/Nouns/TreeTypes_Genitive_Masculine</li>
    <li>treegen_f->Words/Nouns/TreeTypes_Genitive_Feminine</li>
    <li>veggen_m->Words/Nouns/Vegetables_Genitive_Masculine</li>
    <li>veggen_f->Words/Nouns/Vegetables_Genitive_Feminine</li>
    <!-- persone (famiglia/alleati) come descrittori al genitivo: come fr
         ("de le [PersonAlly]") ed es ("del [PersonAlly]"), non in apposizione. -->
    <li>famgen_m->Words/Nouns/People_Family_Genitive_Masculine</li>
    <li>famgen_f->Words/Nouns/People_Family_Genitive_Feminine</li>
    <li>allygen_m->Words/Nouns/People_Allies_Genitive_Masculine</li>
    <li>allygen_f->Words/Nouns/People_Allies_Genitive_Feminine</li>
  </NamerTraderGeneral.rulePack.rulesFiles>

  <!-- EN:
    <li>r_name(p=4)->[businessname] [businesstype]</li>
    <li>r_name->[NamePerson] [businesstype]</li>
    <li>r_name->[maybe_adjective] [Animal] [businesstype]</li>
    <li>r_name->[Letter][Letter] [businesstype]</li>
    <li>r_name(p=0.5)->[PersonAlly] [businesstype]</li>
    <li>r_name(p=0.5)->[AdjectiveFriendly] [businesstype]</li>
    <li>r_name(p=0.5)->[AdjectiveBadass] [businesstype]</li>
    <li>r_name(p=0.3)->[PersonFamily] [businesstype]</li>
    <li>r_name(p=0.3)->[maybe_adjective] [NaturalObject] [businesstype]</li>
    <li>r_name(p=0.2)->[maybe_adjective] [TreeType] [businesstype]</li>
    <li>r_name(p=0.2)->[maybe_adjective] [Vegetable] [businesstype]</li>
    <li>r_name(p=0.2)->[Direction] [businesstype]</li>
    <li>maybe_adjective-></li>
    <li>maybe_adjective->[Color]</li>
    <li>maybe_adjective->[AdjectiveFriendly]</li>
    <li>maybe_adjective->[AdjectiveBadass]</li>
  -->
  <NamerTraderGeneral.rulePack.rulesStrings>
    <!-- IT: nomi commerciali ricostruiti con accordo di genere/numero (modello
         dei namer Factions/Settlement). L'inglese mette il modificatore davanti
         alla "testa" ([adj/animale] [businesstype]); in italiano:
         - solo i marchi/sigle/nomi propri ([businessname], [NamePerson]) restano
           in apposizione (ordine EN), sono grammaticali in qualunque caso;
         - i descrittori (animale, oggetto naturale, albero, ortaggio) e le persone
           comuni (alleato, famiglia) seguono il businesstype come testa con un
           genitivo ("Compagnia del toporagno", "Consorzio dello zio"): preposizione
           articolata fusa e accordata (del/dello/dell'/della, liste *_Genitive_*);
           per animali/oggetti colore/aggettivo posposto e concordato col nome, per
           le persone nessun aggettivo (come fr/es);
         - l'aggettivo riferito direttamente al businesstype usa sottoinsiemi di
           businesstype divisi per genere/numero (Friendly solo singolare: mancano
           le varianti plurali);
         - [Direction] reso con complemento invariante ("del nord", "dell'est").
         Pesi: mantenuti gli stessi totali dell'EN (Friendly 0.5 = 0.25x2,
         Badass 0.5 = 0.13x4). -->
    <li>r_name(p=4)->[businessname] [businesstype]</li>
    <li>r_name->[NamePerson] [businesstype]</li>
    <li>r_name->[Letter][Letter] [businesstype]</li>
    <!-- persone comuni (alleato/famiglia): genitivo su testa nominale, non
         apposizione. "Difensore commercianti"/"Zio partner" non sono italiano;
         fr/es rendono entrambi col genitivo ("de le [PersonAlly]", "del [PersonAlly]"). -->
    <li>r_name(p=0.5)->[btype_head] [allybrand]</li>
    <li>r_name(p=0.3)->[btype_head] [familybrand]</li>
    <!-- descrittori con accordo (testa = btype_head, solo nomi, non aggettivali) -->
    <li>r_name->[btype_head] [animalbrand]</li>
    <li>r_name(p=0.3)->[btype_head] [natbrand]</li>
    <li>r_name(p=0.2)->[btype_head] [treebrand]</li>
    <li>r_name(p=0.2)->[btype_head] [vegbrand]</li>
    <!-- aggettivo concordato direttamente col businesstype -->
    <li>r_name(p=0.25)->[btype_ms] [AdjectiveFriendlyMS]</li>
    <li>r_name(p=0.25)->[btype_fs] [AdjectiveFriendlyFS]</li>
    <li>r_name(p=0.13)->[btype_ms] [AdjectiveBadassMS]</li>
    <li>r_name(p=0.13)->[btype_fs] [AdjectiveBadassFS]</li>
    <li>r_name(p=0.13)->[btype_mp] [AdjectiveBadassMP]</li>
    <li>r_name(p=0.13)->[btype_fp] [AdjectiveBadassFP]</li>
    <!-- direzione come complemento invariante -->
    <li>r_name(p=0.2)->[btype_head] [dir_compl]</li>
    <!-- marchi descrittivi al genitivo ("businesstype + del/della Y"); il genere
         lo porta il file *_Genitive_*, colore/aggettivo posposto concordato.
         2/8 ~ 25% senza aggettivo, come l'EN. -->
    <li>animalbrand->[animalgen_m]</li>
    <li>animalbrand->[animalgen_f]</li>
    <li>animalbrand->[animalgen_m] [Color_Masculine]</li>
    <li>animalbrand->[animalgen_f] [Color_Feminine]</li>
    <li>animalbrand->[animalgen_m] [AdjectiveFriendlyMS]</li>
    <li>animalbrand->[animalgen_f] [AdjectiveFriendlyFS]</li>
    <li>animalbrand->[animalgen_m] [AdjectiveBadassMS]</li>
    <li>animalbrand->[animalgen_f] [AdjectiveBadassFS]</li>
    <li>natbrand->[natgen_m]</li>
    <li>natbrand->[natgen_f]</li>
    <li>natbrand->[natgen_m] [Color_Masculine]</li>
    <li>natbrand->[natgen_f] [Color_Feminine]</li>
    <li>natbrand->[natgen_m] [AdjectiveFriendlyMS]</li>
    <li>natbrand->[natgen_f] [AdjectiveFriendlyFS]</li>
    <li>natbrand->[natgen_m] [AdjectiveBadassMS]</li>
    <li>natbrand->[natgen_f] [AdjectiveBadassFS]</li>
    <li>treebrand->[treegen_m]</li>
    <li>treebrand->[treegen_f]</li>
    <li>treebrand->[treegen_m] [Color_Masculine]</li>
    <li>treebrand->[treegen_f] [Color_Feminine]</li>
    <li>treebrand->[treegen_m] [AdjectiveFriendlyMS]</li>
    <li>treebrand->[treegen_f] [AdjectiveFriendlyFS]</li>
    <li>treebrand->[treegen_m] [AdjectiveBadassMS]</li>
    <li>treebrand->[treegen_f] [AdjectiveBadassFS]</li>
    <li>vegbrand->[veggen_m]</li>
    <li>vegbrand->[veggen_f]</li>
    <li>vegbrand->[veggen_m] [Color_Masculine]</li>
    <li>vegbrand->[veggen_f] [Color_Feminine]</li>
    <li>vegbrand->[veggen_m] [AdjectiveFriendlyMS]</li>
    <li>vegbrand->[veggen_f] [AdjectiveFriendlyFS]</li>
    <li>vegbrand->[veggen_m] [AdjectiveBadassMS]</li>
    <li>vegbrand->[veggen_f] [AdjectiveBadassFS]</li>
    <!-- marchi "persona" al genitivo (senza colore/aggettivo: "del compagno
         verde" non ha senso su una persona; anche fr/es li tengono nudi) -->
    <li>allybrand->[allygen_m]</li>
    <li>allybrand->[allygen_f]</li>
    <li>familybrand->[famgen_m]</li>
    <li>familybrand->[famgen_f]</li>
    <!-- sottoinsiemi di businesstype per genere/numero (accordo aggettivo;
         esclusi incorporata/interplanetaria/interstellare: già aggettivali) -->
    <li>btype_ms->consorzio</li>
    <li>btype_ms->partner</li>
    <li>btype_fs->compagnia</li>
    <li>btype_fs->corporazione</li>
    <li>btype_fs->società di esportazione</li>
    <li>btype_fs->società di importazione</li>
    <li>btype_fs->società di trasporti</li>
    <li>btype_fs->società di transito</li>
    <li>btype_mp->commercianti</li>
    <li>btype_mp->viaggiatori</li>
    <li>btype_mp->titoli</li>
    <li>btype_mp->lubrificanti</li>
    <li>btype_fp->industrie</li>
    <li>btype_fp->spedizioni</li>
    <li>btype_fp->soluzioni</li>
    <!-- testa "nominale" per i descrittori: unione dei soli businesstype-nome -->
    <li>btype_head->[btype_ms]</li>
    <li>btype_head->[btype_fs]</li>
    <li>btype_head->[btype_mp]</li>
    <li>btype_head->[btype_fp]</li>
    <!-- complementi di direzione invarianti (validi con qualsiasi businesstype) -->
    <li>dir_compl->del nord</li>
    <li>dir_compl->del sud</li>
    <li>dir_compl->dell'est</li>
    <li>dir_compl->dell'ovest</li>
    <li>dir_compl->del nord-est</li>
    <li>dir_compl->del nord-ovest</li>
    <li>dir_compl->del sud-est</li>
    <li>dir_compl->del sud-ovest</li>
  </NamerTraderGeneral.rulePack.rulesStrings>
  
</LanguageData>